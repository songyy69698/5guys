# Dollarprinter 交易日志路径（指向你的 Dollarprinter data 目录）
TRADES_PATH=/Users/darrenmac14/Vibe-coding/Dollarprinter/data

# Gemini API Key（从 aistudio.google.com 获取）
GEMINI_API_KEY=

# Gemini 模型（默认 gemini-2.0-flash）
GEMINI_MODEL=gemini-2.0-flash

# Telegram 通知（可选，复用 Dollarprinter 的 bot）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
